# Local environment variables for JyotiCreationProj
# Rename this file to .env in the project root.

SECRET_KEY=replace_this_with_a_secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
USE_SQLITE=True

# PostgreSQL settings are ignored when USE_SQLITE=True
DB_NAME=jyoti_saree_db
DB_USER=jyoti_saree_user
DB_PASSWORD=jyoti_saree_password
DB_HOST=localhost
DB_PORT=5432
